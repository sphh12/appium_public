# Sample Appium Test - Environment Variables Template
# 이 파일을 .env로 복사한 후 실제 값을 입력하세요.
# cp .env.example .env (또는 PowerShell: Copy-Item .env.example .env)

# ===========================================
# 테스트 계정 정보 (필수)
# ===========================================
# Staging 테스트 계정
STG_ID=your_staging_username
STG_PW=your_staging_pin

# Live 테스트 계정
LIVE_ID=your_live_username
LIVE_PW=your_live_password

# 간편비밀번호 4자리 (로그인 후 설정용)
SIMPLE_PIN=1234

# ===========================================
# 앱 설정
# ===========================================
# APP_ENV (stage/live/livetest)에 따라 resource-id 접두사, 계정이 자동 전환됩니다.
# 기본값을 변경하려면 아래 주석을 해제하세요.
# STG_RESOURCE_ID_PREFIX=com.example.remittance.stag:id
# LIVE_RESOURCE_ID_PREFIX=com.example.remittance:id
# LIVETEST_RESOURCE_ID_PREFIX=com.example.remittance:id

# APK 폴더 구조 (파일명 지정 불필요, 폴더 내 .apk 자동 탐색)
# apk/stage/    ← Staging APK
# apk/live/     ← Live APK
# apk/livetest/ ← LiveTest APK
# 각 폴더에 .apk 파일을 넣으면 자동으로 인식됩니다.
# 여러 파일이 있으면 이름순 마지막(최신) 파일을 사용합니다.

# ===========================================
# 디바이스 설정 (선택사항)
# ===========================================
# 실물 디바이스 시리얼 (adb devices로 확인)
# 에뮬레이터 사용 시 주석 처리
# ANDROID_UDID=XXXXXXXX

# 디바이스 이름 (Allure 리포트 표시용)
# ANDROID_DEVICE_NAME=My Device

# Android OS 버전
# ANDROID_PLATFORM_VERSION=12

# ===========================================
# Appium 서버 설정 (선택사항)
# ===========================================
# Appium 서버 호스트 (기본: 127.0.0.1)
# APPIUM_HOST=127.0.0.1

# Appium 서버 포트 (기본: 4723)
# APPIUM_PORT=4723

# ===========================================
# Vercel Blob Storage (대시보드 첨부파일 업로드용, 선택사항)
# ===========================================
# Vercel Blob 읽기/쓰기 토큰 (미설정 시 첨부파일 업로드 건너뜀)
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxx

# ===========================================
# iOS 설정 (macOS에서만 사용)
# ===========================================
# iOS 시뮬레이터 이름
# IOS_DEVICE_NAME=iPhone 15

# iOS 버전
# IOS_PLATFORM_VERSION=17.0

# 앱 번들 ID
# IOS_BUNDLE_ID=com.example.app
